TMUX_SESSION="ai-work"

# 絶対パス（cron の貧弱な PATH 対策）
# which claude / which codex で確認してから設定する
CLAUDE_CMD="$HOME/.local/bin/claude"
CODEX_CMD="$HOME/.nvm/versions/node/vX.Y.Z/bin/codex"

# 各ツールの起動ディレクトリ
CLAUDE_WORKDIR="$HOME/repos/ai-session-refresher"
CODEX_WORKDIR="$HOME/repos/ai-session-refresher"

# pane 起動完了を待つ最大秒数
CLAUDE_WAIT_MAX=20
CODEX_WAIT_MAX=15
POLL_INTERVAL=1

# pane ID 保存先
STATE_DIR="$HOME/.cache/ai-session-refresher"
CLAUDE_PANE_FILE="$STATE_DIR/claude.pane"
CODEX_PANE_FILE="$STATE_DIR/codex.pane"

# ログ
LOG_FILE="$HOME/.local/log/ai-session-refresher.log"
LOCK_FILE="$STATE_DIR/refresh.lock"
